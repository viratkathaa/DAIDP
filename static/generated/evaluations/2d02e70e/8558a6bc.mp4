s historias.\n\nSi sientes la misma curiosidad y ganas de crear,\nbienvenido a esta aventura audiovisual.\n\nPara sponsors del canal: widesilvente@nextlytalent.com\nPara proyectos: Hola@widesilvente.es / https://widesilvente.es/\n"},"callToAction":{"simpleText":"VISIT CHANNEL"},"dismiss":{"simpleText":"CANCEL"},"endpoint":{"clickTrackingParams":"CAYQ-N4BGAAiEwiYyJ20ovKTAxWxlekFHfNsAU8yDGl2LWVuZHNjcmVlbkjD4JqWjvLnqETKAQTwWj1V","commandMetadata":{"webCommandMetadata":{"url":"/channel/UCs0UwSeekLcehYMG_m1wJjQ","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCs0UwSeekLcehYMG_m1wJjQ"}},"hovercardButton":{"subscribeButtonRenderer":{"buttonText":{"runs":[{"text":"SUBSCRIBE"}]},"subscribed":false,"enabled":true,"type":"FREE","channelId":"UCs0UwSeekLcehYMG_m1wJjQ","showPreferences":false,"subscribedButtonText":{"runs":[{"text":"SUBSCRIBED"}]},"unsubscribedButtonText":{"runs":[{"text":"SUBSCRIBE"}]},"trackingParams":"CAcQmysiEwiYyJ20ovKTAxWxlekFHfNsAU8yDGl2LWVuZHNjcmVlbg==","unsubscribeButtonText":{"runs":[{"text":"UNSUBSCRIBE"}]},"serviceEndpoints":[{"clickTrackingParams":"CAcQmysiEwiYyJ20ovKTAxWxlekFHfNsAU8yDGl2LWVuZHNjcmVlbsoBBPBaPVU=","commandMetadata":{"webCommandMetadata":{"sendPost":true,"apiUrl":"/youtubei/v1/subscription/subscribe"}},"subscribeEndpoint":{"channelIds":["UCs0UwSeekLcehYMG_m1wJjQ"],"params":"EgIIBBgA"}},{"clickTrackingParams":"CAcQmysiEwiYyJ20ovKTAxWxlekFHfNsAU_KAQTwWj1V","commandMetadata":{"webCommandMetadata":{"sendPost":true}},"signalServiceEndpoint":{"signal":"CLIENT_SIGNAL","actions":[{"clickTrackingParams":"CAcQmysiEwiYyJ20ovKTAxWxlekFHfNsAU_KAQTwWj1V","openPopupAction":{"popup":{"confirmDialogRenderer":{"trackingParams":"CAgQxjgiEwiYyJ20ovKTAxWxlekFHfNsAU8=","dialogMessages":[{"runs":[{"text":"Unsubscribe from "},{"text":"Wide Silvente | Audiovisual con IA"},{"text":"?"}]}],"confirmButton":{"buttonRenderer":{"style":"STYLE_BLUE_TEXT","size":"SIZE_DEFAULT","isDisabled":false,"text