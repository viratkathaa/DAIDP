simpleText":"94,214"},"label":{"simpleText":"Views"},"accessibilityText":"94,214 views","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4293983231,"raisedBackground":4293983231,"additiveBackground":556641761,"textPrimary":4278398013,"textSecondary":4279398550,"invertedBackground":4279398550,"overlayBackground":3422759997},"darkThemeColorPalette":{"baseBackground":4278261022,"raisedBackground":4278398013,"additiveBackground":724413921,"textPrimary":4292736253,"textSecondary":4287945204,"invertedBackground":4285713133,"overlayBackground":3422759997},"enableColorSampledText":true}},"viewCountType":"VIEW_COUNT_FACTOID_TYPE_TOTAL_VIEWS"}},{"factoidRenderer":{"value":{"simpleText":"27 Apr"},"label":{"simpleText":"2025"},"accessibilityText":"27 Apr 2025","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4293983231,"raisedBackground":4293983231,"additiveBackground":556641761,"textPrimary":4278398013,"textSecondary":4279398550,"invertedBackground":4279398550,"overlayBackground":3422759997},"darkThemeColorPalette":{"baseBackground":4278261022,"raisedBackground":4278398013,"additiveBackground":724413921,"textPrimary":4292736253,"textSecondary":4287945204,"invertedBackground":4285713133,"overlayBackground":3422759997},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBMQ040EGAUiEwi73520ovKTAxX_UTgFHbvKMZXKAQTwWj1V","commandMetadata":{"webCommandMetadata":{"url":"/@WideSilvente","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCs0UwSeekLcehYMG_m1wJjQ","canonicalBaseUrl":"/@WideSilvente"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/sCoBT-kWZOehyq8Lva053YmU9tVu3o78u4wsJrWN5dJ7ezT5OGEx3AofUI9Swriqgw6V5LY6=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"What if a Nike ad could capture the unstoppable spirit of athletes—without filming a single real scene?\n\nThis is an electrifying short film created entirely with artificial intelligence.\nEvery sprint, every dunk, every impossible move… was generated with cutting-edge AI tools. But the drive? That came from me.\n\n🏆 It’s not just a commercial. It’s a celebration of ambition—a cinematic tribute to every dream fueled by motion, sweat, and belief.\n\n🔧 Tools Used:\n\nAI Imagery: Midjourney, Flux, Veo Imagen 3\n\nVideo: Veo 2, Kling AI 2.0\n\nMusic: Suno AI\n\nVoice: Elevenlabs\n\nConcept, Script, Direction \u0026 Editing: 100% Human\n\n🔥 This project explores how AI can amplify the raw energy of human ambition, when guided by real passion and purpose. Nike didn’t make this film. But their story—and our dreams—did.\n\n👉 AI is not the athlete. We are.\n\n#Nike #AITools #AICommercial #AthleteSpirit #EmotionalAI #SunoAI #ElevenLabs #Veo2 #Midjourney #AIFilmmaking #GenerativeAI #DreamBig #klingai \n‪@Kling_ai‬ ‪@googledeepmind‬ ‪@elevenlabsio‬","commandRuns":[{"startIndex":840,"length":5,"onTap":{"innertubeCommand":{"clickTrackingParams":"CDYQ3NcEGFMiEwi73520ovKTAxX_UTgFHbvKMZXKAQTwWj1V","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/nike","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUICgRuaWtlGAE%3D"}}},"loggingDirectives":{"trackingParams":"CDYQ3NcEGFMiEwi73520ovKTAxX_UTgFHbvKMZU="}},{"startIndex":846,"length":8,"onTap":{"innertubeCommand":{"clickTrackingParams":"CDUQ3NcEGFQiEwi73520ovKTAxX_UTgFHbvKMZXKAQTwWj1V","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/aitools","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gULCgdhaXRvb2