uided by real passion and purpose. Nike didn’t make this film. But their story—and our dreams—did.\n\n👉 AI is not the athlete. We are.\n\n#Nike #AITools #AICommercial #AthleteSpirit #EmotionalAI #SunoAI #ElevenLabs #Veo2 #Midjourney #AIFilmmaking #GenerativeAI #DreamBig #klingai \n‪@Kling_ai‬ ‪@googledeepmind‬ ‪@elevenlabsio‬","commandRuns":[{"startIndex":840,"length":5,"onTap":{"innertubeCommand":{"clickTrackingParams":"CK0CENzXBBggIhMIu9-dtKLykwMV_1E4BR27yjGVygEE8Fo9VQ==","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/nike","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUICgRuaWtlGAE%3D"}}},"loggingDirectives":{"trackingParams":"CK0CENzXBBggIhMIu9-dtKLykwMV_1E4BR27yjGV"}},{"startIndex":846,"length":8,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKwCENzXBBghIhMIu9-dtKLykwMV_1E4BR27yjGVygEE8Fo9VQ==","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/aitools","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gULCgdhaXRvb2xzGAE%3D"}}},"loggingDirectives":{"trackingParams":"CKwCENzXBBghIhMIu9-dtKLykwMV_1E4BR27yjGV"}},{"startIndex":855,"length":13,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKsCENzXBBgiIhMIu9-dtKLykwMV_1E4BR27yjGVygEE8Fo9VQ==","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/aicommercial","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"FEhashtag","params":"6gUQCgxhaWNvbW1lcmNpYWwYAQ%3D%3D"}}},"loggingDirectives":{"trackingParams":"CKsCENzXBBgiIhMIu9-dtKLykwMV_1E4BR27yjGV"}},{"startIndex":869,"length":14,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKoCENzXBBgjIhMIu9-dtKLykwMV_1E4BR27yjGVygEE8Fo9VQ==","commandMetadata":{"webCommandMetadata":{"url":"/hashtag/athletespirit","webPageType":"WEB_PAGE_TYPE_BROWSE","rootVe":6827,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":