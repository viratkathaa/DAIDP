# Main AI Provider for heavier creative generation: "gemini" or "openai"
AI_PROVIDER=gemini

# Groq API Key for lightweight tasks like brief/tag generation
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Demo mode: set to "false" to use live model calls
DEMO_MODE=false
